flowchart TB
    click_src["Pointer click<br/>input.rs:836"]
    scroll_src["Scroll wheel<br/>input.rs:894"]
    destroyed_src["Toplevel destroyed<br/>lib.rs:2984"]
    activation_src["xdg_activation<br/>lib.rs:3222"]
    foreign_src["foreign_toplevel<br/>lib.rs:3255"]
    newsurface_src["New surface created"]
    closesurface_src["Surface closed"]
    waybar_src["Waybar click<br/>workspace protocol"]
    hotplug_src["Hotplug / Resume"]
    xdg_fs_req["xdg_toplevel<br/>set_fullscreen"]
    xdg_unfs_req["xdg_toplevel<br/>unset_fullscreen"]
    foreign_fs["foreign_toplevel<br/>set/unset_fullscreen"]

    focusev["Event::Focus"]
    newev["Event::New"]
    closeev["Event::Close"]
    wsev["Event::ActivateWorkspace"]
    outev["Event::OutputsComplete"]
    fsev["Event::FullscreenRequest"]
    unfsev["Event::UnfullscreenRequest"]

    click_src -->|notify| focusev
    scroll_src -->|notify| focusev
    destroyed_src -->|notify| focusev
    activation_src -->|notify| focusev
    foreign_src -->|notify| focusev
    newsurface_src --> newev
    closesurface_src --> closeev
    waybar_src --> wsev
    hotplug_src --> outev
    xdg_fs_req --> fsev
    xdg_unfs_req --> unfsev
    foreign_fs --> fsev
    foreign_fs --> unfsev

    focusev -->|pipe fd| dispatch
    newev -->|pipe fd| dispatch
    closeev -->|pipe fd| dispatch
    wsev -->|pipe fd| dispatch
    outev -->|pipe fd| dispatch
    fsev -->|pipe fd| dispatch
    unfsev -->|pipe fd| dispatch

    dispatch["ewm--handle-event"]

    dispatch -->|focus| hfocus["ewm--handle-focus"]
    dispatch -->|new| hnew["ewm--handle-new-surface"]
    dispatch -->|close| hclose["ewm--handle-close-surface"]
    dispatch -->|activate_workspace| hws["ewm--handle-activate-workspace"]
    dispatch -->|outputs_complete| hout["ewm--handle-outputs-complete"]
    dispatch -->|fullscreen_request| hfs["ewm--handle-fullscreen-request"]
    dispatch -->|unfullscreen_request| hunfs["ewm--handle-unfullscreen-request"]

    focus_guard{"minibuffer<br/>active?"}:::guard
    focus_drop(["Dropped"]):::safe

    hfocus --> focus_guard
    focus_guard -->|Yes| focus_drop
    focus_guard -->|No| lookup["Lookup buffer +<br/>find window"]
    lookup --> winfound{"window<br/>found?"}
    winfound -->|Yes| selwin["select-frame +<br/>select-window"]
    winfound -->|No| popbuf["pop-to-buffer-same-window"]
    selwin --> hooks["window hooks →<br/>send-layouts + sync-focus"]
    popbuf --> hooks
    hooks --> dedup{"already<br/>focused?"}
    dedup -->|Yes| noop(["No-op"]):::safe
    dedup -->|No| sendfocus["ewm-focus-module"]

    hnew --> create_buf["Create buffer"]
    create_buf --> new_guard{"minibuffer<br/>active?"}:::guard
    new_guard -->|Yes| bufonly(["Buffer only"]):::safe
    new_guard -->|No| target["select-frame for output +<br/>pop-to-buffer-same-window"]
    target --> hooks

    ws_guard{"minibuffer<br/>active?"}:::guard
    ws_drop(["Dropped"]):::safe

    hws --> ws_guard
    ws_guard -->|Yes| ws_drop
    ws_guard -->|No| tabswitch["tab-bar-select-tab"]
    tabswitch --> hooks

    hclose --> killbuf["kill-buffer"]:::muted
    hout --> parity["apply-output-config +<br/>enforce parity +<br/>layout refresh +<br/>sync-focus"]:::muted

    hfs --> set_param["set ewm-fullscreen<br/>per-frame"]
    set_param --> refresh_fs["ewm-layout--refresh"]
    refresh_fs --> layout_send["ewm-output-layout →<br/>apply_output_layout"]

    hunfs --> clear_param["clear ewm-fullscreen<br/>per-frame"]
    clear_param --> refresh_unfs["ewm-layout--refresh"]
    refresh_unfs --> layout_send

    %% ── Keyboard fullscreen gate (input.rs) ──

    keypress["Key pressed<br/>handle_keyboard_event"]
    fs_check{"focused surface<br/>fullscreen?"}:::guard
    fs_restore["Restore focus<br/>to fullscreen surface"]
    fs_allow_check{"allow_fullscreen<br/>& !focus_on_emacs?"}:::guard
    fs_forward(["Forward to surface"]):::safe

    keypress --> fs_check
    fs_check -->|No| normal_intercept["Normal intercept<br/>(code 1 → redirect)"]
    fs_check -->|Yes| fs_restore
    fs_restore --> fs_allow_check
    fs_allow_check -->|Yes| normal_intercept
    fs_allow_check -->|No| fs_forward

    subgraph Legend
        direction LR
        leg_guard["Orange: guard / decision"]:::guard
        leg_safe(["Green: safe / forwarded"]):::safe
        leg_muted["Gray: inherently safe"]:::muted
    end

    classDef safe fill:#d4edda,stroke:#28a745,color:#155724
    classDef guard fill:#ffeeba,stroke:#856404,color:#856404,stroke-width:2px
    classDef muted fill:#e2e3e5,stroke:#6c757d,color:#383d41
